AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# Preferred: use AWS_PROFILE via ~/.aws/credentials or AWS SSO.
# Only uncomment these if you intentionally want raw credentials in your local .env.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

EC2_KEY=my-keypair
EC2_SG=sg-0123456789abcdef0
EC2_BUCKET=s3://my-tarok-checkpoints

# Optional. Leave blank to use the default VPC/subnet path.
EC2_SUBNET=

# Good default for this repo's 1-hour training config.
EC2_INSTANCE_TYPE=g5.2xlarge
EC2_SPOT_PRICE=1.20
EC2_INSTANCE_PROFILE=ec2-s3-tarok

# Use auto to resolve the latest Deep Learning GPU Ubuntu AMI in the selected region.
TAROK_EC2_AMI=auto

MODEL=checkpoints/Petra_Novak/iter_090.pt
CONFIG=ec2-g5-1h