#!/usr/bin/env bash
# Pre-commit hook: formatting, linting, type checks, tests, and coverage guard.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
BASELINE_FILE="$ROOT/.coverage-baseline"
UV_CMD="uv run --default-index https://pypi.org/simple"

echo "──────────────────────────────────────"
echo "  Pre-commit checks"
echo "──────────────────────────────────────"

# ── 1. Frontend quality checks ──────────────
echo ""
echo "▶ Frontend checks…"
cd "$ROOT/frontend"

if node -e "const s=require('./package.json').scripts||{}; process.exit(s['format:check'] ? 0 : 1)"; then
  echo "  • format:check"
  npm run -s format:check
else
  echo "  • format:check not configured (skipped)"
fi

if node -e "const s=require('./package.json').scripts||{}; process.exit(s.lint ? 0 : 1)"; then
  echo "  • lint"
  npm run -s lint
else
  echo "  • lint not configured (skipped)"
fi

echo "  • type-check"
npx tsc -b --noEmit
echo "  • unit tests"
npx vitest run
echo "  ✔ Frontend OK"

# ── 2. Backend format + lint ────────────────
echo ""
echo "▶ Backend linting/format checks…"
cd "$ROOT/backend"
PYTHONPATH=src:../model/src $UV_CMD ruff format --check src tests
PYTHONPATH=src:../model/src $UV_CMD ruff check src tests
echo "  ✔ Backend lint/format OK"

# ── 3. Optional backend type-check (ty) ──────
echo ""
echo "▶ Backend static typing…"
if [ "${ENABLE_TY:-0}" = "1" ]; then
  if PYTHONPATH=src:../model/src $UV_CMD python -c "import importlib.util, sys; sys.exit(0 if importlib.util.find_spec('ty') else 1)"; then
    PYTHONPATH=src:../model/src $UV_CMD ty check src/tarok
    echo "  ✔ ty OK"
  else
    echo "  • ty not installed (skipped)"
  fi
else
  echo "  • ty disabled (set ENABLE_TY=1 to enable)"
fi

# ── 4. Backend tests with coverage ──────────
echo ""
echo "▶ Backend tests + coverage…"
TORCH_LIB_DIR=$(PYTHONPATH=src:../model/src $UV_CMD python -c "import pathlib, torch; print(pathlib.Path(torch.__file__).resolve().parent / 'lib')")
export DYLD_FALLBACK_LIBRARY_PATH="$TORCH_LIB_DIR:${DYLD_FALLBACK_LIBRARY_PATH:-}"

if ! PYTHONPATH=src:../model/src $UV_CMD python -c "import tarok_engine" >/dev/null 2>&1; then
  echo "  • tarok_engine missing, building Rust extension..."
  LIBTORCH_USE_PYTORCH=1 $UV_CMD maturin develop --release --manifest-path ../engine-rs/Cargo.toml
fi

PYTHONPATH=src:../model/src PYTHONHASHSEED=0 $UV_CMD \
  python -m pytest tests/ -q \
    -p no:randomly --hypothesis-seed=0 \
    --cov=tarok \
    --cov-report=term-missing:skip-covered \
    --cov-report=json:coverage.json

# ── 4b. Training-lab tests ───────────────────
echo ""
echo "▶ Training-lab tests…"
cd "$ROOT/backend"
PYTHONHASHSEED=0 PYTHONPATH=src:../model/src:../training-lab $UV_CMD \
  python -m pytest ../training-lab/tests/ -q \
    -p no:randomly --hypothesis-seed=0
echo "  ✔ Training-lab OK"

NEW_PCT=$(python3 -c "import json; print(round(json.load(open('coverage.json'))['totals']['percent_covered'], 2))")
echo "  Current coverage: ${NEW_PCT}%"

# ── 5. Coverage regression check ────────────
if [ -f "$BASELINE_FILE" ]; then
  OLD_PCT=$(cat "$BASELINE_FILE")
  echo "  Baseline coverage: ${OLD_PCT}%"
  python3 -c "
import sys
new, old = float('${NEW_PCT}'), float('${OLD_PCT}')
TOLERANCE = 0.5  # allow minor run-to-run fluctuation (Hypothesis, etc.)
if new < old - TOLERANCE:
    print(f'  ❌  Coverage dropped from {old}% to {new}% (>{TOLERANCE}% regression). Commit rejected.')
    print('  Tip: run \"make update-coverage-baseline\" after intentionally removing dead code.')
    sys.exit(1)
print('  ✅  Coverage did not decrease.')
if new > old:
    with open('$BASELINE_FILE', 'w') as f:
        f.write(str(new))
    print(f'  📈  Baseline auto-updated to {new}%')
"
else
  echo "  No baseline found — saving ${NEW_PCT}% as initial baseline."
  echo "${NEW_PCT}" > "$BASELINE_FILE"
fi

rm -f "$ROOT/backend/coverage.json"

echo ""
echo "──────────────────────────────────────"
echo "  All checks passed ✅"
echo "──────────────────────────────────────"
